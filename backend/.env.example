# Backend — Variables de entorno

# Port del servidor
PORT=3001

# URL del Frontend (CORS)
FRONTEND_URL=http://localhost:3000

# OpenAI API Key (Obtenela en platform.openai.com)
# Si la dejás vacía, el servidor funcionará en modo "Mock" respondiendo textos simulados gratuitamente
OPENAI_API_KEY=

# Firebase Admin SDK (Obtené este JSON desde:
# console.firebase.google.com → Tu Proyecto → Configuración → Cuentas de Servicio → Generar nueva clave privada)
FIREBASE_PROJECT_ID=mi-proyecto-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMirey+Larga=\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@mi-proyecto-id.iam.gserviceaccount.com
